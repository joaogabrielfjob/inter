{
  "name": "server",
  "main": "index.js",
  "module": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --production --compile --target bun --outfile server --minify-whitespace --minify-syntax",
    "start": "bun run ./build/index.js",
    "db:deploy": "bun prisma migrate deploy",
    "db:generate": "bun prisma generate"
  },
  "private": true,
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7",
    "@types/node": "^24.13.3",
    "dotenv": "^17.2.4",
    "elysia": "^1.4.29",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prisma": "7"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
