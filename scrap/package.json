{
  "name": "scrap",
  "main": "index.js",
  "module": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --production --target bun --outdir build --minify",
    "start": "bun run ./build/index.js",
    "db:deploy": "bun prisma migrate deploy",
    "db:generate": "bun prisma generate"
  },
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@types/node": "^24.7.1",
    "puppeteer": "^24.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.17.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
